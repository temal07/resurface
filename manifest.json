{
    "manifest_version": 3,
    "name": "Resurface - Rediscover forgotten pages you've saved or searched before while browsing.",
    "version": "0.0.1",
    "description": "Resurface helps you rediscover contextually relevant pages you've searched or saved in the past, saving you time from regoogling.",
    "permissions": ["bookmarks", "storage", "tabs", "activeTab", "history", "scripting"],
    "host_permissions": ["https://*/*", "http://*/*"],
    "web_accessible_resources": [
        {
            "resources": ["utils/helpers.js"],
            "matches": ["<all_urls>"]
        }
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/resurface_logo.png",
            "32": "icons/resurface_logo.png",
            "48": "icons/resurface_logo.png",
            "128": "icons/resurface_logo.png"
        }
    },
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content.js"],
            "run_at": "document_idle"
        }
    ]
}